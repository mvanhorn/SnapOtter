---
// biome-ignore-all lint/correctness/noUnusedImports: Astro template consumes component imports.
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template consumes frontmatter values.
import Footer from "@/components/Footer.astro";
import JsonLd from "@/components/JsonLd.astro";
import Navbar from "@/components/Navbar.astro";
import { LANDING_LOCALES, t } from "@/i18n";
import Base from "@/layouts/Base.astro";
import { localizeHref } from "@/lib/i18n-page";

export function getStaticPaths() {
  return LANDING_LOCALES.map((locale) => ({
    params: { locale: locale === "en" ? undefined : locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;
const PATH = "/terms";

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://snapotter.com" },
    {
      "@type": "ListItem",
      position: 2,
      name: "Terms and Conditions",
      item: "https://snapotter.com/terms",
    },
  ],
};
---

<Base
  title={t(locale, "terms.metaTitle")}
  description={t(locale, "terms.metaDescription")}
  canonical={`https://snapotter.com${localizeHref(locale, PATH)}`}
  locale={locale}
  path={PATH}
>
  <Fragment slot="head">
    <JsonLd data={breadcrumbJsonLd} />
  </Fragment>

  <Navbar locale={locale} />

  <main id="main" class="px-6 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="mx-auto max-w-3xl">
      <div class="reveal text-center">
        <h1 class="font-display text-4xl font-bold tracking-tight md:text-5xl">
          {t(locale, "terms.title")}
        </h1>
        <p class="mt-6 text-lg text-muted">{t(locale, "terms.lastUpdated")}</p>
      </div>

      <div class="mt-16 space-y-12 text-sm leading-relaxed text-muted">
        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.whoWeAre.title")}</h2>
          <p class="mt-3">
            {t(locale, "terms.whoWeAre.body")}
          </p>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.overview.title")}</h2>
          <p class="mt-3">
            {t(locale, "terms.overview.body")}
          </p>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.license.title")}</h2>
          <ul class="mt-3 list-disc space-y-2 ps-5">
            <li>{t(locale, "terms.license.item1")}</li>
            <li>{t(locale, "terms.license.item2")}</li>
            <li>{t(locale, "terms.license.item3")}</li>
            <li>
              {t(locale, "terms.license.item4.pre")}
              <a
                href="mailto:contact@snapotter.com"
                class="text-primary font-medium hover:underline underline-offset-4"
              >
                contact@snapotter.com
              </a>
              {t(locale, "terms.license.item4.post")}
            </li>
          </ul>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.website.title")}</h2>
          <ul class="mt-3 list-disc space-y-2 ps-5">
            <li>{t(locale, "terms.website.item1")}</li>
            <li>{t(locale, "terms.website.item2")}</li>
          </ul>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.selfHosted.title")}</h2>
          <ul class="mt-3 list-disc space-y-2 ps-5">
            <li>{t(locale, "terms.selfHosted.item1")}</li>
            <li>{t(locale, "terms.selfHosted.item2")}</li>
            <li>{t(locale, "terms.selfHosted.item3")}</li>
          </ul>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.ip.title")}</h2>
          <ul class="mt-3 list-disc space-y-2 ps-5">
            <li>{t(locale, "terms.ip.item1")}</li>
            <li>{t(locale, "terms.ip.item2")}</li>
          </ul>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.liability.title")}</h2>
          <p class="mt-3">
            {t(locale, "terms.liability.body")}
          </p>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.changes.title")}</h2>
          <p class="mt-3">
            {t(locale, "terms.changes.body")}
          </p>
        </section>

        <section class="reveal">
          <h2 class="text-lg font-semibold text-foreground">{t(locale, "terms.contact.title")}</h2>
          <p class="mt-3">
            {t(locale, "terms.contact.pre")}
            <a
              href="mailto:contact@snapotter.com"
              class="text-primary font-medium hover:underline underline-offset-4"
            >
              contact@snapotter.com
            </a>.
          </p>
        </section>
      </div>
    </div>
  </main>

  <Footer locale={locale} path={PATH} />
</Base>
